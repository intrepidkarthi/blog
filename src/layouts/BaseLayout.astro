---
import "../styles/global.css";
import MatrixRain from "../components/MatrixRain.astro";
import BootSequence from "../components/BootSequence.astro";
import TabBar from "../components/TabBar.astro";
import StatusBar from "../components/StatusBar.astro";
import InteractiveTerminal from "../components/InteractiveTerminal.astro";

interface Props {
  title: string;
  description?: string;
  active?: string;
  file?: string;
  ogImage?: string;
  canonicalUrl?: string;
  ogType?: "website" | "article";
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;
  tags?: string[];
  jsonLd?: unknown;
  noindex?: boolean;
}
const {
  title,
  description = "Karthikeyan NG — Engineer, author, speaker. Full-time perpetual futures trader. Crypto + AI infrastructure since 2008.",
  active = "home",
  file,
  ogImage = "/og-default.svg",
  canonicalUrl,
  ogType = "website",
  publishedTime,
  modifiedTime,
  author = "Karthikeyan NG",
  tags = [],
  jsonLd,
  noindex = false,
} = Astro.props;

const fullTitle = title === "intrepidkarthi" ? title : `${title} · intrepidkarthi`;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;
const canonicalHref = canonicalUrl ?? pageUrl;
const ogImageAbs = new URL(ogImage, Astro.site).href;

// Default JSON-LD: WebSite + Person on home, BlogPosting on articles, otherwise none
const defaultJsonLd =
  jsonLd
    ? jsonLd
    : ogType === "article"
      ? {
          "@context": "https://schema.org",
          "@type": "BlogPosting",
          headline: title,
          description,
          datePublished: publishedTime,
          dateModified: modifiedTime ?? publishedTime,
          author: {
            "@type": "Person",
            name: author,
            url: "https://intrepidkarthi.com",
            sameAs: [
              "https://twitter.com/intrepidkarthi",
              "https://github.com/intrepidkarthi",
              "https://linkedin.com/in/intrepidkarthi",
            ],
          },
          publisher: {
            "@type": "Person",
            name: "Karthikeyan NG",
            url: "https://intrepidkarthi.com",
          },
          mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
          image: ogImageAbs,
          keywords: tags.join(", "),
        }
      : active === "home"
        ? {
            "@context": "https://schema.org",
            "@type": "WebSite",
            name: "intrepidkarthi",
            url: "https://intrepidkarthi.com",
            description,
            author: {
              "@type": "Person",
              name: "Karthikeyan NG",
              alternateName: "intrepidkarthi",
              jobTitle: "Engineer · Author · Speaker · Trader",
              url: "https://intrepidkarthi.com",
              email: "intrepidkarthi@gmail.com",
              sameAs: [
                "https://twitter.com/intrepidkarthi",
                "https://github.com/intrepidkarthi",
                "https://linkedin.com/in/intrepidkarthi",
                "https://feaws.xyz",
                "https://getdailyvox.com",
                "https://www.amazon.com/dp/B07JKWLH3G",
              ],
              knowsAbout: [
                "Crypto Infrastructure",
                "Stablecoin Settlement",
                "Quantitative Trading",
                "Perpetual Futures",
                "Machine Learning",
                "Mobile AI",
                "Information Security",
              ],
            },
            potentialAction: {
              "@type": "SearchAction",
              target: "https://intrepidkarthi.com/writing?q={search_term_string}",
              "query-input": "required name=search_term_string",
            },
          }
        : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="theme-color" content="#030604" />
    <meta name="color-scheme" content="dark" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="intrepidkarthi" />
    <link rel="apple-touch-icon" href="/favicon.svg" />

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={author} />

    {tags.length > 0 && <meta name="keywords" content={tags.join(", ")} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title="intrepidkarthi" href="/rss.xml" />
    <link rel="canonical" href={canonicalHref} />
    <link rel="me" href="https://twitter.com/intrepidkarthi" />
    <link rel="me" href="https://github.com/intrepidkarthi" />

    <!-- Open Graph -->
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:site_name" content="intrepidkarthi" />
    <meta property="og:locale" content="en_US" />
    {ogType === "article" && publishedTime && (
      <meta property="article:published_time" content={publishedTime} />
    )}
    {ogType === "article" && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime} />
    )}
    {ogType === "article" && (
      <meta property="article:author" content="https://intrepidkarthi.com/about" />
    )}
    {ogType === "article" && tags.map((t) => (
      <meta property="article:tag" content={t} />
    ))}

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@intrepidkarthi" />
    <meta name="twitter:creator" content="@intrepidkarthi" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <!-- Structured data -->
    {defaultJsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(defaultJsonLd)} />
    )}

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=VT323&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <MatrixRain />
    <BootSequence />

    <div id="app">
      <TabBar active={active} />
      <main class="main">
        <slot />
      </main>
      <InteractiveTerminal />
      <StatusBar file={file ?? `~/intrepidkarthi/${active}`} />
    </div>

    <style>
      #app {
        position: relative;
        z-index: 5;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        opacity: 0;
        animation: fade-in 0.5s ease forwards;
        animation-delay: 0.2s;
      }
      @keyframes fade-in {
        to { opacity: 1; }
      }
      .main {
        flex: 1;
        /* bottom padding clears the fixed terminal (36px) + status bar (28px) + breathing room */
        padding: 24px 28px 96px;
        max-width: 1180px;
        width: 100%;
        margin: 0 auto;
      }
      @media (max-width: 700px) {
        .main { padding: 18px 16px 84px; }
      }
    </style>
  </body>
</html>
