---
interface Props {
  href: string;
  date: Date | string;
  title: string;
  tags?: string[];
  excerpt?: string;
}
const { href, date, title, tags = [], excerpt } = Astro.props;
const dateStr = typeof date === "string" ? date : date.toISOString().slice(0, 10);
const tagStr = tags.length ? `[${tags.slice(0, 2).join(" · ")}]` : "";
---

<a class="post-card" href={href}>
  <span class="date">{dateStr}</span>
  <span class="body">
    {tagStr && <span class="tag">{tagStr}</span>}
    <span class="title">{title}</span>
    {excerpt && <span class="excerpt">{excerpt}</span>}
  </span>
</a>

<style>
  .post-card {
    display: grid;
    grid-template-columns: 110px 1fr;
    gap: 14px;
    padding: 10px 8px;
    border-bottom: 1px dashed var(--line);
    align-items: baseline;
    cursor: pointer;
    transition: background .15s, border-left-color .15s;
    border-left: 2px solid transparent;
    text-decoration: none;
    color: var(--ink);
  }
  .post-card:hover {
    background: var(--bg2);
    border-left-color: var(--green);
  }
  .post-card .date {
    color: var(--amber);
    font-size: 12.5px;
    white-space: nowrap;
  }
  .post-card .body {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .post-card .body .tag {
    color: var(--cyan);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
  }
  .post-card .body .title {
    color: var(--ink);
    font-size: 14px;
    line-height: 1.3;
  }
  .post-card:hover .body .title {
    color: var(--green-bright);
  }
  .post-card .body .excerpt {
    color: var(--dim);
    font-size: 12.5px;
    margin-top: 4px;
  }
</style>
