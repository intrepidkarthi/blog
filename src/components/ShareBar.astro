---
interface Props {
  title: string;
  url?: string;
}
const { title, url } = Astro.props;
---

<div class="share-bar" data-title={title} data-url={url}>
  <span class="share-label">share →</span>
  <button class="share-btn share-linkedin" title="Share on LinkedIn" aria-label="Share on LinkedIn">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
  </button>
  <button class="share-btn share-twitter" title="Share on X/Twitter" aria-label="Share on X/Twitter">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
  </button>
  <button class="share-btn share-copy" title="Copy link" aria-label="Copy link">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 007.54.54l3-3a5 5 0 00-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 00-7.54-.54l-3 3a5 5 0 007.07 7.07l1.71-1.71"/></svg>
    <span class="copy-toast">copied!</span>
  </button>
</div>

<style>
  .share-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 0;
    margin: 16px 0;
    border-top: 1px dashed var(--line);
    border-bottom: 1px dashed var(--line);
  }
  .share-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--dim);
    text-transform: uppercase;
    letter-spacing: 1.5px;
  }
  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border: 1px solid var(--line);
    background: var(--bg2);
    color: var(--dim);
    cursor: pointer;
    transition: all 0.15s ease;
    position: relative;
  }
  .share-btn:hover {
    border-color: var(--green);
    color: var(--green);
    background: rgba(78,255,124,0.05);
  }
  .share-linkedin:hover { color: #0a66c2; border-color: #0a66c2; }
  .share-twitter:hover { color: var(--ink); border-color: var(--ink); }
  .share-copy:hover { color: var(--cyan); border-color: var(--cyan); }

  .copy-toast {
    position: absolute;
    top: -28px;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--green);
    background: var(--bg);
    border: 1px solid var(--green);
    padding: 2px 8px;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
    white-space: nowrap;
  }
  .copy-toast.show {
    opacity: 1;
  }
</style>

<script>
  document.querySelectorAll('.share-bar').forEach((bar) => {
    const title = bar.getAttribute('data-title') || document.title;
    const url = bar.getAttribute('data-url') || window.location.href;

    bar.querySelector('.share-linkedin')?.addEventListener('click', () => {
      window.open(
        `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`,
        '_blank',
        'width=600,height=500'
      );
    });

    bar.querySelector('.share-twitter')?.addEventListener('click', () => {
      window.open(
        `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`,
        '_blank',
        'width=600,height=400'
      );
    });

    const copyBtn = bar.querySelector('.share-copy');
    const toast = copyBtn?.querySelector('.copy-toast');
    copyBtn?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(url);
      toast?.classList.add('show');
      setTimeout(() => toast?.classList.remove('show'), 1500);
    });
  });
</script>
