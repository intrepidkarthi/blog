---
// Global interactive shell — collapsed by default, click bar or press `/` to open.
// Commands: help, whoami, ls, cat, writing, lab, mission, about, contact,
// joke, theme, matrix, snake, 42, konami, clear, date, pwd, uptime, echo
---

<div class="terminal collapsed" id="ikt-terminal">
  <div class="term-bar" id="ikt-term-bar">
    <span class="chevron">▾</span>
    <span class="label">[shell]</span>
    <span class="prompt-prefix">Karthikeyan NG:~$</span>
    <span class="hint-text">power-user mode — type <span class="hl">help</span> for commands</span>
    <span class="kb-hint">
      <kbd>/</kbd> focus
      <kbd>esc</kbd> close
    </span>
  </div>
  <div class="term-body" id="ikt-term-body">
    <div id="ikt-out"></div>
    <div class="input-line">
      <span class="prompt">
        <span class="u">Karthikeyan</span> <span class="h">NG</span>:<span class="d">~</span>$
      </span>
      <input
        id="ikt-cmd"
        type="text"
        autocomplete="off"
        autocapitalize="off"
        spellcheck="false"
        aria-label="terminal input"
      />
    </div>
  </div>
</div>

<div class="ikt-toast" id="ikt-toast">
  <div class="head" id="ikt-toast-head">★ Achievement</div>
  <div class="body" id="ikt-toast-body"></div>
</div>

<style>
  .terminal {
    background: var(--bg);
    border-top: 1px solid var(--line);
    flex-shrink: 0;
    transition: height 0.3s ease;
    height: 280px;
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 10;
  }
  .terminal.collapsed { height: 36px; }

  .term-bar {
    background: var(--bg2);
    border-bottom: 1px solid var(--line);
    padding: 8px 16px;
    font-size: 11.5px;
    display: flex; align-items: center; gap: 10px;
    color: var(--dim);
    cursor: pointer;
    user-select: none;
    flex-shrink: 0;
    flex-wrap: nowrap;
    overflow: hidden;
  }
  .term-bar:hover { color: var(--green-bright); }
  .term-bar .chevron {
    font-family: var(--font-vt);
    font-size: 16px;
    transition: transform 0.3s;
  }
  .terminal.collapsed .term-bar .chevron { transform: rotate(-90deg); }
  .term-bar .label { color: var(--green); }
  .term-bar .prompt-prefix { color: var(--ink); white-space: nowrap; }
  .term-bar .hint-text {
    color: var(--dim);
    flex: 1;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .term-bar .hl { color: var(--green-bright); }
  .term-bar .kb-hint {
    color: var(--dim);
    white-space: nowrap;
  }
  .term-bar kbd {
    background: var(--bg3);
    color: var(--green-bright);
    border: 1px solid var(--green-dim);
    border-radius: 3px;
    padding: 0 5px;
    font-family: inherit;
    font-size: 10px;
    margin: 0 2px;
  }
  @media (max-width: 700px) {
    .term-bar .hint-text, .term-bar .kb-hint { display: none; }
  }

  .term-body {
    flex: 1;
    padding: 12px 18px;
    overflow-y: auto;
    font-size: 12.5px;
    cursor: text;
  }
  .terminal.collapsed .term-body { display: none; }
  .term-body::-webkit-scrollbar { width: 6px; }
  .term-body::-webkit-scrollbar-thumb { background: var(--line-bright); }

  #ikt-out { font-family: var(--font-mono); }
  #ikt-out .l { white-space: pre-wrap; word-break: break-word; line-height: 1.55; }
  #ikt-out .pl { color: var(--green-bright); margin-top: 6px; }
  #ikt-out .pl .u { color: var(--green); }
  #ikt-out .pl .h { color: var(--cyan); }
  #ikt-out .pl .d { color: var(--amber); }
  #ikt-out .pl .cmd { color: var(--ink); }
  #ikt-out .ok { color: var(--green-bright); }
  #ikt-out .info { color: var(--cyan); }
  #ikt-out .warn { color: var(--warn); }
  #ikt-out .err { color: var(--red); }
  #ikt-out .pink { color: var(--pink); }
  #ikt-out .purple { color: var(--purple); }
  #ikt-out .dim { color: var(--dim); }
  #ikt-out .accent { color: var(--amber); }
  #ikt-out a { color: var(--cyan); text-decoration: underline; }
  #ikt-out a:hover { color: var(--green-bright); }
  #ikt-out .ascii {
    color: var(--green-bright);
    font-family: var(--font-vt);
    font-size: 13px;
    line-height: 1.05;
    text-shadow: 0 0 6px var(--green-glow);
    white-space: pre;
  }
  #ikt-out table { width: 100%; border-collapse: collapse; }
  #ikt-out td { padding: 2px 6px 2px 0; vertical-align: top; }
  #ikt-out td.k { color: var(--green); width: 130px; white-space: nowrap; }
  #ikt-out td.v { color: var(--ink); }

  .input-line {
    display: flex; align-items: center; gap: 6px;
    margin-top: 6px; font-size: 13px;
  }
  .input-line .prompt { white-space: nowrap; }
  .input-line .prompt .u { color: var(--green); }
  .input-line .prompt .h { color: var(--cyan); }
  .input-line .prompt .d { color: var(--amber); }
  .input-line input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--ink);
    font-family: var(--font-mono);
    font-size: 13px;
    caret-color: var(--green-bright);
  }

  /* Achievement toast */
  .ikt-toast {
    position: fixed;
    right: 16px;
    bottom: 56px;
    z-index: 100;
    background: var(--bg2);
    color: var(--green-bright);
    border: 1px solid var(--green);
    padding: 10px 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    min-width: 240px;
    max-width: 320px;
    box-shadow: 0 0 16px var(--green-glow);
    transform: translateX(420px);
    transition: transform 0.4s ease;
  }
  .ikt-toast.show { transform: translateX(0); }
  .ikt-toast .head {
    color: var(--amber);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 4px;
  }
  .ikt-toast .body { color: var(--ink); font-size: 12.5px; }

  /* Mini snake game frame */
  .ikt-game-frame {
    border: 1px solid var(--green);
    padding: 4px;
    background: var(--bg2);
    display: inline-block;
    margin: 6px 0;
  }
  .ikt-game-frame canvas {
    display: block;
    image-rendering: pixelated;
  }
</style>

<script is:inline>
  (() => {
    const term = document.getElementById("ikt-terminal");
    const bar = document.getElementById("ikt-term-bar");
    const body = document.getElementById("ikt-term-body");
    const out = document.getElementById("ikt-out");
    const cmdInput = document.getElementById("ikt-cmd");
    const toast = document.getElementById("ikt-toast");
    const toastHead = document.getElementById("ikt-toast-head");
    const toastBody = document.getElementById("ikt-toast-body");
    const matrixCanvas = document.getElementById("matrix-canvas");

    let history = [];
    let historyIdx = -1;
    const achievements = new Set();
    let theme = "green";

    // ---------- helpers ----------
    function append(html) {
      const d = document.createElement("div");
      d.className = "l";
      d.innerHTML = html;
      out.appendChild(d);
      body.scrollTop = body.scrollHeight;
    }
    function appendPrompt(cmd) {
      append(
        '<span class="pl"><span class="u">Karthikeyan</span> <span class="h">NG</span>:<span class="d">~</span>$ <span class="cmd">' +
          escapeHtml(cmd) +
          "</span></span>"
      );
    }
    function escapeHtml(s) {
      return s.replace(/[&<>"']/g, (c) =>
        ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[c])
      );
    }

    // ---------- nerd helpers ----------
    const _rand = (lo, hi) => Math.random() * (hi - lo) + lo;
    const _fmtUSD = (n) => "$" + n.toLocaleString("en-US", { maximumFractionDigits: n > 100 ? 0 : 2 });
    const _arrow = (n) => n >= 0
      ? `<span class="ok">▲ ${n.toFixed(2)}%</span>`
      : `<span class="err">▼ ${Math.abs(n).toFixed(2)}%</span>`;
    const _bar = (val, max = 100, w = 30) => {
      const filled = Math.max(0, Math.min(w, Math.round((val / max) * w)));
      return "█".repeat(filled) + "░".repeat(w - filled);
    };
    const _spark = (vals) => {
      const chars = "▁▂▃▄▅▆▇█";
      const lo = Math.min(...vals), hi = Math.max(...vals);
      return vals.map(v => chars[Math.floor(((v - lo) / (hi - lo || 1)) * 7)]).join("");
    };
    const _randSeq = (n, lo = 0, hi = 100) => Array.from({ length: n }, () => _rand(lo, hi));
    function unlockAchievement(key, title, msg) {
      if (achievements.has(key)) return;
      achievements.add(key);
      toastHead.textContent = "★ Achievement · " + title;
      toastBody.textContent = msg;
      toast.classList.add("show");
      setTimeout(() => toast.classList.remove("show"), 3600);
    }

    // ---------- commands ----------
    const COMMANDS = {
      help() {
        return `<span class="info">commands · grouped</span>

<span class="accent">nav</span>      whoami · writing · lab · mission · about · contact · ls · cd
<span class="accent">files</span>    cat &lt;file&gt; (ambitions.md, wishlist.md, now.md)
<span class="accent">crypto</span>   btc · eth · sol · gas · fear · greed · funding · block · halving · whales · liq
<span class="accent">ai/ml</span>    gpu · models · tokenize &lt;text&gt; · embed &lt;text&gt; · agi · params
<span class="accent">system</span>   neofetch · ping &lt;host&gt; · traceroute · top · htop · curl &lt;host&gt;
<span class="accent">stats</span>    streak · setup · bookshelf · stack · uptime · date · pwd
<span class="accent">fun</span>      joke · fortune · cowsay &lt;text&gt; · figlet &lt;text&gt; · theme · matrix
<span class="accent">hidden</span>   snake · 42 · konami · sl · vim · :wq · sudo · hack the planet
<span class="accent">util</span>     clear · echo &lt;text&gt;

<span class="dim">tip: tabs above are clickable. press 1-6 to navigate. TAB autocompletes.</span>`;
      },
      whoami() {
        unlockAchievement("whoami", "Identified", "You met Karthik");
        return `<pre class="ascii">       .--.
      |o_o |    karthik <span class="info">@</span> intrepidkarthi
      |:_/ |    ────────────────────────────
     //   \\ \\   role     : <span class="accent">Engineer · Author · Speaker</span>
    (|     | )  trading  : <span class="accent">full-time perpetual futures</span>
    /'\\_   _/\\\` since    : 2008 · 16+ years shipping
    \\___)=(___/ books    : <span class="info">2</span> (Mobile ML &amp; AI Projects)</pre>
<span class="ok">▸</span> Builder-Architect. Crypto + AI + trading infrastructure.
<span class="ok">▸</span> Madurai → Bengaluru → Dubai. 18× hackathon · 1× TEDx.
<span class="ok">▸</span> Mission: <span class="accent">$3M FIRE life</span>.
<span class="dim">▸</span> Try: <span class="info">cat ambitions.md</span> · <span class="info">writing</span> · <span class="info">lab</span>`;
      },
      about() { window.location.href = "/about"; return '<span class="ok">▸</span> opening /about'; },
      writing() { window.location.href = "/writing"; return '<span class="ok">▸</span> opening /writing'; },
      posts() { return COMMANDS.writing(); },
      lab() { window.location.href = "/lab"; return '<span class="ok">▸</span> opening /lab'; },
      mission() { window.location.href = "/mission"; return '<span class="ok">▸</span> opening /mission'; },
      goals() { return COMMANDS.mission(); },
      wishlist() { return COMMANDS.mission(); },
      contact() { window.location.href = "/contact"; return '<span class="ok">▸</span> opening /contact'; },
      hire() { return COMMANDS.contact(); },
      home() { window.location.href = "/"; return '<span class="ok">▸</span> /'; },
      cd(arg) {
        const p = (arg || "~").replace(/^[~\/]+/, "").replace(/\/$/, "").toLowerCase();
        const map = { "": "/", "home": "/", "writing": "/writing", "posts": "/writing",
                      "lab": "/lab", "about": "/about", "mission": "/mission",
                      "goals": "/mission", "contact": "/contact" };
        if (p in map) { window.location.href = map[p]; return `<span class="ok">▸</span> ~/${p || "home"}`; }
        return `<span class="err">cd: ${escapeHtml(p)}: no such directory</span>`;
      },
      ls() {
        return `<table>
<tr><td class="k"><a href="/">home/</a></td><td class="v">→ landing · whoami + recent posts</td></tr>
<tr><td class="k"><a href="/writing">writing/</a></td><td class="v">→ blog posts since 2008</td></tr>
<tr><td class="k"><a href="/lab">lab/</a></td><td class="v">→ feaws · dailyvox · books</td></tr>
<tr><td class="k"><a href="/mission">mission/</a></td><td class="v">→ 21 goals · wishlist</td></tr>
<tr><td class="k"><a href="/about">about/</a></td><td class="v">→ full bio</td></tr>
<tr><td class="k"><a href="/contact">contact/</a></td><td class="v">→ hire me · social</td></tr>
</table>`;
      },
      dir() { return COMMANDS.ls(); },
      cat(arg) {
        if (!arg) return '<span class="err">cat: missing operand</span>';
        const f = arg.replace(/^\.\//, "").toLowerCase();
        const files = {
          "ambitions.md": '<span class="info"># ambitions.md</span>\n<span class="ok">▸</span> Build a $100M+ infrastructure company\n<span class="ok">▸</span> Hit $3M FIRE through compounding\n<span class="ok">▸</span> Mentor 100 builders to ship\n<span class="ok">▸</span> Write book #3 — agent infra\n<span class="dim">▸ [done] Speak at TEDx</span>\n<span class="dim">▸ [done] Win 10+ hackathons</span>',
          "wishlist.md": '<span class="info"># wishlist.md</span>\n<span class="pink">◇</span> MacBook Pro M5\n<span class="pink">◇</span> Bose QC Ultra\n<span class="pink">◇</span> Madurai sabbatical (1 month)\n<span class="pink">◇</span> Russell first edition\n<span class="pink">◇</span> Polymarket position that prints',
          "now.md": '<span class="info"># now.md</span>\n<span class="ok">▸</span> Full-time trading on perpetual futures\n<span class="ok">▸</span> feaws.xyz — public quant lab\n<span class="ok">▸</span> Dailyvox — local-LLM iOS app\n<span class="ok">▸</span> 412-day #healthywealthy streak'
        };
        if (files[f]) return files[f];
        return `<span class="err">cat: ${escapeHtml(f)}: no such file</span>\n<span class="dim">try: ambitions.md, wishlist.md, now.md</span>`;
      },
      date() { return new Date().toString(); },
      pwd() { return "/home/karthik"; },
      uptime() { return 'up <span class="accent">6,560+ days</span> since 2008-08 · <span class="ok">412-day</span> streak'; },

      theme() {
        const themes = ["green", "amber", "cyan", "pink", "purple"];
        theme = themes[(themes.indexOf(theme) + 1) % themes.length];
        const map = { green: "#4eff7c", amber: "#ffb454", cyan: "#5fd7ff", pink: "#ff5f87", purple: "#c780ff" };
        document.documentElement.style.setProperty("--green", map[theme]);
        document.documentElement.style.setProperty("--green-bright", map[theme]);
        unlockAchievement("theme", "Style", "Cycled the palette");
        return `<span class="ok">theme:</span> ${theme} <span class="dim">(run again to cycle)</span>`;
      },
      matrix() {
        if (matrixCanvas) {
          matrixCanvas.classList.add("boost");
          setTimeout(() => matrixCanvas.classList.remove("boost"), 5000);
        }
        unlockAchievement("matrix", "Wake up", "You took the green pill");
        return '<span class="ok">▸</span> wake up, neo. <span class="dim">(5s)</span>';
      },
      joke() {
        const jokes = [
          "There are only 10 kinds of people: those who understand binary, and those who don't.",
          'A SQL query walks into a bar, walks up to two tables, and asks: "Can I join you?"',
          "Why do programmers prefer dark mode? Because light attracts bugs.",
          "!false — funny because it's true.",
          "I would tell you a UDP joke, but you might not get it.",
          "Two engineers walk into a bar. They argue for an hour about whether it's a bar or a tavern.",
          "Crypto doesn't lie. People who hold crypto lie about their cost basis.",
          "My favorite kind of music? Algo-rhythms.",
          "There are 2 hard problems in CS: cache invalidation, naming things, and off-by-one errors.",
          "Stablecoins are a great solution to a problem regulators created and then forgot about.",
        ];
        return '<span class="info">▸</span> ' + jokes[Math.floor(Math.random() * jokes.length)];
      },

      // ---------- crypto / trading ----------
      btc() {
        unlockAchievement("trader", "Trader", "Checked the tape");
        const price = 97500 + _rand(-2500, 3500);
        const change = _rand(-3.5, 4);
        const series = _randSeq(24, 90, 105);
        return `<span class="accent">BTC/USDT</span>  ${_fmtUSD(price)}  ${_arrow(change)}\n` +
          `<span class="dim">24h:</span>  ${_spark(series)}\n` +
          `<span class="dim">snapshot · live data + signals at <a href="https://feaws.xyz" target="_blank">feaws.xyz</a></span>`;
      },
      eth() {
        const price = 3650 + _rand(-180, 250);
        const change = _rand(-4, 5);
        const series = _randSeq(24, 95, 105);
        return `<span class="accent">ETH/USDT</span>  ${_fmtUSD(price)}  ${_arrow(change)}\n` +
          `<span class="dim">24h:</span>  ${_spark(series)}\n` +
          `<span class="dim">snapshot · feaws.xyz</span>`;
      },
      sol() {
        const price = 195 + _rand(-15, 25);
        const change = _rand(-6, 8);
        return `<span class="accent">SOL/USDT</span>  ${_fmtUSD(price)}  ${_arrow(change)}\n` +
          `<span class="dim">snapshot · feaws.xyz</span>`;
      },
      gas() {
        const slow = Math.floor(_rand(8, 18));
        const avg = slow + Math.floor(_rand(2, 8));
        const fast = avg + Math.floor(_rand(3, 12));
        return `<span class="accent">ETH gas (gwei)</span>\n` +
          `  slow:    <span class="info">${slow}</span>   ~5 min\n` +
          `  average: <span class="ok">${avg}</span>   ~30 sec\n` +
          `  fast:    <span class="warn">${fast}</span>   ~10 sec\n` +
          `<span class="dim">always verify on etherscan before signing</span>`;
      },
      fear() {
        const v = Math.floor(_rand(20, 80));
        let label, color;
        if (v < 25) { label = "EXTREME FEAR"; color = "err"; }
        else if (v < 45) { label = "FEAR"; color = "warn"; }
        else if (v < 55) { label = "NEUTRAL"; color = "dim"; }
        else if (v < 75) { label = "GREED"; color = "ok"; }
        else { label = "EXTREME GREED"; color = "pink"; }
        return `<span class="accent">Crypto Fear &amp; Greed Index</span>\n` +
          `  <span class="${color}">${v.toString().padStart(3)} / 100  ·  ${label}</span>\n` +
          `  ${_bar(v, 100, 30)}\n` +
          `  <span class="dim">0 = panic · 100 = euphoria</span>`;
      },
      greed() { return COMMANDS.fear(); },
      funding() {
        return `<span class="accent">perpetual funding rates · 8h annualized</span>
<table>
<tr><td class="k">BTC-PERP</td><td class="v"><span class="ok">+0.012%</span> · longs pay shorts</td></tr>
<tr><td class="k">ETH-PERP</td><td class="v"><span class="warn">−0.008%</span> · shorts pay longs</td></tr>
<tr><td class="k">SOL-PERP</td><td class="v"><span class="ok">+0.024%</span></td></tr>
<tr><td class="k">RNDR-PERP</td><td class="v"><span class="ok">+0.041%</span> ★ hot</td></tr>
<tr><td class="k">DOGE-PERP</td><td class="v"><span class="warn">−0.018%</span></td></tr>
</table>
<span class="dim">snapshot · live signals at feaws.xyz</span>`;
      },
      block() {
        const h = 870000 + Math.floor(_rand(0, 5000));
        const next = 1050000;
        const diff = next - h;
        const yrs = (diff * 10 / 60 / 24 / 365).toFixed(1);
        return `<span class="accent">BTC</span>  block  <span class="ok">${h.toLocaleString()}</span>\n` +
          `next halving:  block ${next.toLocaleString()}\n` +
          `                ${diff.toLocaleString()} blocks · ~${yrs} years\n` +
          `<span class="dim">avg block ~10 min</span>`;
      },
      halving() { return COMMANDS.block(); },
      whales() {
        return `<span class="accent">recent whale movements · 24h</span>
<table>
<tr><td class="k">19:42 UTC</td><td class="v">2,400 BTC → Coinbase  <span class="warn">[possible sell]</span></td></tr>
<tr><td class="k">17:15 UTC</td><td class="v">15,000 ETH → unknown  <span class="dim">[accumulation?]</span></td></tr>
<tr><td class="k">14:08 UTC</td><td class="v">820 BTC ← Binance     <span class="ok">[withdrawal]</span></td></tr>
<tr><td class="k">11:22 UTC</td><td class="v">9,300 ETH ← Kraken    <span class="ok">[withdrawal]</span></td></tr>
</table>
<span class="dim">snapshot · whales lie sometimes</span>`;
      },
      liq() {
        const total = (_rand(80, 380)).toFixed(1);
        const longs = (_rand(40, 70)).toFixed(0);
        return `<span class="accent">liquidations · last 24h</span>\n` +
          `total: <span class="warn">$${total}M</span>\n` +
          `  longs:  ${longs}%  ${_bar(longs, 100, 24)}\n` +
          `  shorts: ${100-longs}%  ${_bar(100-longs, 100, 24)}\n` +
          `<span class="dim">cascade threshold approached at 09:14 UTC</span>`;
      },
      liquidations() { return COMMANDS.liq(); },

      // ---------- ai / ml ----------
      gpu() {
        return `<pre class="ascii">+-----------------------------------------------------------+
| NVIDIA-SMI · driver 555.42  ·  CUDA 12.5                  |
+-----------------------------------------------------------+
| GPU 0   M3 Max (Apple)       Temp: 52°C   Power:  21W     |
|         VRAM: 18.2 / 64.0 GB                              |
|         Utilization: 87%                                  |
|         Process:  ollama serve · llama-3.3-70b-instruct   |
+-----------------------------------------------------------+
| GPU 1   RTX 4090 (cloud)     Temp: 47°C   Power:  85W     |
|         VRAM: 21.4 / 24.0 GB                              |
|         Utilization: 94%                                  |
|         Process:  vllm · qwen2.5-coder-32b                |
+-----------------------------------------------------------+</pre>
<span class="dim">M3 Max for dailyvox · 4090 for the heavier work</span>`;
      },
      models() {
        return `<span class="accent">models on hand</span>
<table>
<tr><td class="k">llama-3.3-70b</td><td class="v"><span class="ok">●</span> local · 40GB · default</td></tr>
<tr><td class="k">qwen-2.5-coder-32b</td><td class="v"><span class="ok">●</span> local · 18GB · code tasks</td></tr>
