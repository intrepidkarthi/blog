    function runCommand(raw) {
      const cmd = raw.trim();
      appendPrompt(cmd);
      if (!cmd) return;
      history.push(cmd);
      historyIdx = history.length;
      const parts = cmd.split(/\s+/);
      const fn = COMMANDS[parts[0].toLowerCase()];
      if (fn) {
        const r = fn(parts.slice(1).join(" "));
        if (r != null) append(r);
      } else {
        append(
          `<span class="err">command not found:</span> ${escapeHtml(parts[0])}\n<span class="dim">try:</span> <span class="info">help</span>`
        );
      }
    }

    cmdInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        runCommand(cmdInput.value);
        cmdInput.value = "";
      } else if (e.key === "ArrowUp") {
        if (!history.length) return;
        historyIdx = Math.max(0, historyIdx - 1);
        cmdInput.value = history[historyIdx] || "";
        e.preventDefault();
      } else if (e.key === "ArrowDown") {
        if (!history.length) return;
        historyIdx = Math.min(history.length, historyIdx + 1);
        cmdInput.value = history[historyIdx] || "";
        e.preventDefault();
      } else if (e.key === "Tab") {
        e.preventDefault();
        const cur = cmdInput.value.toLowerCase();
        if (!cur) return;
        const m = Object.keys(COMMANDS).filter((c) => c.startsWith(cur));
        if (m.length === 1) cmdInput.value = m[0];
        else if (m.length > 1) append('<span class="dim">→ ' + m.join("  ") + "</span>");
      } else if (e.key === "Escape") {
        term.classList.add("collapsed");
        cmdInput.blur();
      }
    });

    body.addEventListener("click", (e) => {
      if (e.target.tagName !== "A") cmdInput.focus();
    });

    bar.addEventListener("click", () => {
      term.classList.toggle("collapsed");
      if (!term.classList.contains("collapsed")) cmdInput.focus();
    });

    document.addEventListener("keydown", (e) => {
      if (e.target && (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA")) return;
      if (e.key === "/") {
        e.preventDefault();
        term.classList.remove("collapsed");
        cmdInput.focus();
      } else if (e.key === "?") {
        e.preventDefault();
        term.classList.remove("collapsed");
        runCommand("help");
        cmdInput.focus();
      }
    });
