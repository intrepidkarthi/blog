    function runCommand(raw) {
      const cmd = raw.trim();
      appendPrompt(cmd);
      if (!cmd) return;
      history.push(cmd);
      historyIdx = history.length;
      const parts = cmd.split(/\s+/);
      const fn = COMMANDS[parts[0].toLowerCase()];
      if (fn) {
        const r = fn(parts.slice(1).join(" "));
        if (r != null) append(r);
      } else {
        append(
          `<span class="err">command not found:</span> ${escapeHtml(parts[0])}\n<span class="dim">try:</span> <span class="info">help</span>`
        );
      }
    }

    cmdInput.addEventListener("keydown", (e) => {
      if (e.key === "Enter") {
        runCommand(cmdInput.value);
        cmdInput.value = "";
      } else if (e.key === "ArrowUp") {
        if (!history.length) return;
        historyIdx = Math.max(0, historyIdx - 1);
        cmdInput.value = history[historyIdx] || "";
        e.preventDefault();
      } else if (e.key === "ArrowDown") {
        if (!history.length) return;
        historyIdx = Math.min(history.length, historyIdx + 1);
        cmdInput.value = history[historyIdx] || "";
        e.preventDefault();
      } else if (e.key === "Tab") {
        e.preventDefault();
        const cur = cmdInput.value.toLowerCase();
        if (!cur) return;
        const m = Object.keys(COMMANDS).filter((c) => c.startsWith(cur));
        if (m.length === 1) cmdInput.value = m[0];
        else if (m.length > 1) append('<span class="dim">→ ' + m.join("  ") + "</span>");
      } else if (e.key === "Escape") {
        term.classList.add("collapsed");
        cmdInput.blur();
      }
    });

    body.addEventListener("click", (e) => {
      if (e.target.tagName !== "A") cmdInput.focus();
    });

    bar.addEventListener("click", () => {
      term.classList.toggle("collapsed");
      if (!term.classList.contains("collapsed")) cmdInput.focus();
    });

    document.addEventListener("keydown", (e) => {
      if (e.target && (e.target.tagName === "INPUT" || e.target.tagName === "TEXTAREA")) return;
      if (e.key === "/") {
        e.preventDefault();
        term.classList.remove("collapsed");
        cmdInput.focus();
      } else if (e.key === "?") {
        e.preventDefault();
        term.classList.remove("collapsed");
        runCommand("help");
        cmdInput.focus();
      }
    });

    // Konami code
    const konamiSeq = [
      "ArrowUp", "ArrowUp", "ArrowDown", "ArrowDown",
      "ArrowLeft", "ArrowRight", "ArrowLeft", "ArrowRight",
      "b", "a"
    ];
    let konamiIdx = 0;
    document.addEventListener("keydown", (e) => {
      const k = e.key.length === 1 ? e.key.toLowerCase() : e.key;
      if (k === konamiSeq[konamiIdx]) {
        konamiIdx++;
        if (konamiIdx === konamiSeq.length) {
          konamiIdx = 0;
          if (matrixCanvas) {
            matrixCanvas.classList.add("boost");
            setTimeout(() => matrixCanvas.classList.remove("boost"), 6000);
          }
          document.documentElement.style.setProperty("--green", "#ff5f87");
          document.documentElement.style.setProperty("--green-bright", "#ff6be7");
          if (!term.classList.contains("collapsed")) {
            append('<span class="purple">▸ KONAMI ACTIVATED</span> · <span class="dim">extra lives granted.</span>');
          }
          unlockAchievement("konami", "True believer", "You found the konami code");
        }
      } else {
        konamiIdx = 0;
      }
    });

    // Snake game
    function spawnSnake() {
      if (term.classList.contains("collapsed")) term.classList.remove("collapsed");
      const wrap = document.createElement("div");
      wrap.className = "ikt-game-frame";
      const c = document.createElement("canvas");
      c.width = 240; c.height = 160;
      wrap.appendChild(c);
      const status = document.createElement("div");
      status.style.cssText = "font-size:11px; color:var(--dim); margin-top:4px;";
      status.innerHTML = '<span class="info">snake</span> · score <span id="ikt-snake-score" style="color:var(--green-bright)">0</span> · arrow keys · esc to exit';
      out.appendChild(wrap);
      out.appendChild(status);
      body.scrollTop = body.scrollHeight;

      const ctx = c.getContext("2d");
      const cell = 8;
      let snake = [{x:5,y:5},{x:4,y:5},{x:3,y:5}];
      let dir = {x:1,y:0};
      let food = {x:15, y:10};
      let score = 0;
      let alive = true;
      function draw() {
        ctx.fillStyle = "#030604"; ctx.fillRect(0,0,c.width,c.height);
        ctx.fillStyle = "#ff5f87"; ctx.fillRect(food.x*cell, food.y*cell, cell-1, cell-1);
        ctx.fillStyle = "#4eff7c";
        snake.forEach(s => ctx.fillRect(s.x*cell, s.y*cell, cell-1, cell-1));
        if (!alive) {
          ctx.fillStyle = "rgba(0,0,0,0.7)"; ctx.fillRect(0,0,c.width,c.height);
          ctx.fillStyle = "#ff5f87"; ctx.font = "bold 16px monospace"; ctx.textAlign = "center";
          ctx.fillText("GAME OVER", c.width/2, c.height/2);
        }
      }
      function step() {
        if (!alive) return;
        const h = {x: snake[0].x + dir.x, y: snake[0].y + dir.y};
        if (h.x < 0 || h.y < 0 || h.x >= c.width/cell || h.y >= c.height/cell) { alive = false; draw(); return; }
        if (snake.some(s => s.x === h.x && s.y === h.y)) { alive = false; draw(); return; }
        snake.unshift(h);
        if (h.x === food.x && h.y === food.y) {
          score++;
          document.getElementById("ikt-snake-score").textContent = score;
          if (score >= 5) unlockAchievement("snake5", "Snake master", "5 dots");
          food = { x: Math.floor(Math.random()*(c.width/cell)), y: Math.floor(Math.random()*(c.height/cell)) };
        } else { snake.pop(); }
        draw();
      }
      const kh = (e) => {
        if (!alive) return;
        const m = {ArrowUp:{x:0,y:-1}, ArrowDown:{x:0,y:1}, ArrowLeft:{x:-1,y:0}, ArrowRight:{x:1,y:0}};
        if (m[e.key] && (m[e.key].x !== -dir.x || m[e.key].y !== -dir.y)) { dir = m[e.key]; e.preventDefault(); }
        if (e.key === "Escape") { alive = false; draw(); }
      };
      document.addEventListener("keydown", kh);
      const iv = setInterval(() => { step(); if (!alive) { clearInterval(iv); document.removeEventListener("keydown", kh); } }, 110);
      draw();
    }
  })();
</script>
