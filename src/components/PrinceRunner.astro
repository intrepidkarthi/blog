---
// Tiny pixel character that runs across text lines like platforms.
// Inspired by Prince of Persia — lands on text, runs along it, jumps to another line.
---

<canvas id="prince-canvas"></canvas>

<style>
  #prince-canvas {
    position: fixed;
    inset: 0;
    z-index: 50;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    #prince-canvas { display: none; }
  }
</style>

<script is:inline>
(() => {
  const canvas = document.getElementById("prince-canvas");
  if (!canvas) return;
  if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    canvas.style.display = "none";
    return;
  }
  const ctx = canvas.getContext("2d");

  const S = 1.2;
  const COLOR = "#4eff7c";

  // Bresenham line for pixel-perfect drawing
  function drawLine(x0, y0, x1, y1, bx, by) {
    const dx = Math.abs(x1-x0), dy = Math.abs(y1-y0);
    const sx = x0<x1?1:-1, sy = y0<y1?1:-1;
    let err = dx-dy;
    while (true) {
      ctx.fillRect(Math.round(bx+x0*S), Math.round(by+y0*S), Math.ceil(S), Math.ceil(S));
      if (x0===x1 && y0===y1) break;
      const e2 = 2*err;
      if (e2 > -dy) { err -= dy; x0 += sx; }
      if (e2 < dx) { err += dx; y0 += sy; }
    }
  }

  // Head outline (shared)
  const head = [
    [0,-17, 1,-18],[1,-18, 2,-18],[2,-18, 3,-17],[3,-17, 3,-16],
    [3,-16, 2,-15],[2,-15, 1,-15],[1,-15, 0,-16],[0,-16, 0,-17],
    [1,-15, 1,-14], // neck
  ];
  const headHigh = [
    [0,-19, 1,-20],[1,-20, 2,-20],[2,-20, 3,-19],[3,-19, 3,-18],
    [3,-18, 2,-17],[2,-17, 1,-17],[1,-17, 0,-18],[0,-18, 0,-19],
    [1,-17, 1,-16],
  ];

  // === SPRITES ===

  // Run (4 frames)
  const runRight = [
    { lines: [...head, [1,-14,1,-8],
      [1,-13,3,-12],[3,-12,5,-13], [1,-12,-1,-13],[-1,-13,-2,-12],
      [1,-8,3,-5],[3,-5,4,-2],[4,-2,5,0], [1,-8,-1,-5],[-1,-5,-2,-2],[-2,-2,-3,0]]},
    { lines: [...head, [1,-14,1,-8],
      [1,-13,3,-13],[3,-13,4,-12], [1,-12,-1,-12],[-1,-12,-2,-13],
      [1,-8,1,-4],[1,-4,1,0], [1,-8,2,-4],[2,-4,2,0]]},
    { lines: [...head, [1,-14,1,-8],
      [1,-13,-1,-12],[-1,-12,-3,-13], [1,-12,3,-13],[3,-13,4,-12],
      [1,-8,3,-5],[3,-5,4,-2],[4,-2,5,0], [1,-8,-1,-5],[-1,-5,-2,-2],[-2,-2,-3,0]]},
    { lines: [...head, [1,-14,1,-8],
      [1,-13,-1,-12],[-1,-12,-2,-13], [1,-12,3,-13],[3,-13,4,-12],
      [1,-8,1,-4],[1,-4,1,0], [1,-8,2,-4],[2,-4,2,0]]},
  ];

  // Jump (arms reaching up)
  const jumpUp = { lines: [...headHigh, [1,-16,1,-10],
    [1,-15,-1,-17],[-1,-17,-2,-19], [1,-15,3,-17],[3,-17,4,-19],
    [1,-10,3,-9],[3,-9,4,-10], [1,-10,-1,-9],[-1,-9,-2,-10]]};

  // Idle: standing, looking around
  const idleStand = { lines: [...head, [1,-14,1,-8],
    [1,-13,3,-12],[3,-12,4,-11], [1,-12,-1,-11],[-1,-11,-2,-10],
    [1,-8,2,-4],[2,-4,2,0], [1,-8,0,-4],[0,-4,0,0]]};

  // Idle: scratching head
  const idleScratch = { lines: [...head, [1,-14,1,-8],
    [1,-14,2,-16],[2,-16,3,-17], // right hand on head
    [1,-12,-1,-11],[-1,-11,-2,-10],
    [1,-8,2,-4],[2,-4,2,0], [1,-8,0,-4],[0,-4,0,0]]};

  // Idle: looking down (peering off edge)
  const idlePeer = { lines: [
    // head tilted forward/down
    [1,-16, 2,-17],[2,-17, 3,-17],[3,-17, 4,-16],[4,-16, 4,-15],
    [4,-15, 3,-14],[3,-14, 2,-14],[2,-14, 1,-15],[1,-15, 1,-16],
    [2,-14, 2,-13],
    [2,-13,2,-8],
    [2,-12,4,-11],[4,-11,5,-10], [2,-11,0,-10],[0,-10,-1,-9],
    [2,-8,3,-4],[3,-4,3,0], [2,-8,1,-4],[1,-4,1,0]]};

  // Sitting (rest)
  const idleSit = { lines: [...head, [1,-14,1,-10],
    [1,-12,3,-11],[3,-11,4,-10], [1,-11,-1,-10],[-1,-10,-2,-9],
    [1,-10,3,-9],[3,-9,5,-9], // legs out front
    [1,-10,-1,-9],[-1,-9,-3,-9]]};

  // Climb grab
  const climbGrab = { lines: [...head, [1,-14,1,-8],
    [1,-14,-1,-16],[-1,-16,-2,-17], [1,-14,3,-16],[3,-16,4,-17],
    [1,-8,0,-5],[0,-5,-1,-3], [1,-8,2,-5],[2,-5,3,-3]]};

  // Climb pull up
  const climbPull = { lines: [...headHigh, [1,-16,1,-10],
    [1,-14,-1,-13],[-1,-13,-3,-13], [1,-14,3,-13],[3,-13,5,-13],
    [1,-10,2,-8],[2,-8,1,-6], [1,-10,0,-8],[0,-8,1,-6]]};

  // Flip frame (mid-air somersault)
  const flipFrames = [
    { lines: [...headHigh, [1,-16,1,-10], [1,-15,-2,-14], [1,-15,4,-14],
      [1,-10,0,-7], [1,-10,2,-7]]},
    // upside down-ish
    { lines: [[0,-6,1,-5],[1,-5,2,-5],[2,-5,3,-6],[3,-6,3,-7],
      [3,-7,2,-8],[2,-8,1,-8],[1,-8,0,-7],[0,-7,0,-6],
      [1,-8,1,-9],[1,-9,1,-15],
      [1,-10,-1,-11], [1,-10,3,-11],
      [1,-15,0,-17],[0,-17,-1,-18], [1,-15,2,-17],[2,-17,3,-18]]},
    { lines: [...headHigh, [1,-16,1,-10], [1,-15,-2,-14], [1,-15,4,-14],
      [1,-10,0,-7], [1,-10,2,-7]]},
  ];

  function mirrorSprite(spr) {
    return { lines: spr.lines.map(([x1,y1,x2,y2]) => [-x1,y1,-x2,y2]) };
  }

  const runLeft = runRight.map(mirrorSprite);
  const jumpUpLeft = mirrorSprite(jumpUp);
  const climbGrabLeft = mirrorSprite(climbGrab);
  const climbPullLeft = mirrorSprite(climbPull);
  const idlePeerLeft = mirrorSprite(idlePeer);

  // --- Platform detection ---
  function findPlatforms() {
    const platforms = [];
    const selectors = "h1, h2, h3, p, li, time, code, td, th";
    const els = document.querySelectorAll("#app .main " + selectors);
    const seen = new Set();

    for (const el of els) {
      if (!el.offsetParent) continue;
      const text = el.textContent?.trim();
      if (!text || text.length < 3) continue;

      const rect = el.getBoundingClientRect();
      if (rect.width < 40 || rect.height < 10 || rect.height > 50) continue;
      if (rect.top < 40 || rect.bottom > window.innerHeight - 60) continue;

      const key = Math.round(rect.bottom / 6) + ":" + Math.round(rect.left / 15);
      if (seen.has(key)) continue;
      seen.add(key);

      platforms.push({
        x: rect.left,
        y: rect.bottom,
        w: rect.width,
      });
    }
    return platforms;
  }

  // --- State ---
  let platforms = [];
  let prince = {
    x: 100, y: 200, vx: 0, vy: 0,
    facingRight: true,
    onPlatform: null,
    frame: 0, frameTimer: 0,
    state: "falling",
    climbTimer: 0, climbTarget: null,
    idleTimer: 0, idleType: 0,
    flipFrame: 0, flipTimer: 0,
    visitedPlatforms: [],
  };

  const GRAVITY = 0.15;
  const JUMP_FORCE = -4.2;
  const RUN_SPEED = 0.7;
  const FRAME_DELAY = 14;
  const CLIMB_DURATION = 35;
  const PULLUP_DURATION = 18;

  // Pick a platform biased toward ones NOT recently visited and far away
  function pickNextPlatform(current) {
    const valid = platforms.filter(p => p !== current && p.w > 40);
    if (!valid.length) return null;

    const p = prince;
    // Score: prefer distance + not recently visited
    const scored = valid.map(plat => {
      const dist = Math.abs(plat.y - (current ? current.y : p.y)) + Math.abs(plat.x + plat.w/2 - p.x);
      const recentIdx = p.visitedPlatforms.indexOf(plat);
      const recency = recentIdx >= 0 ? (5 - recentIdx) * 80 : 0; // penalty for recent
      return { plat, score: dist - recency + Math.random() * 100 };
    });
    scored.sort((a, b) => b.score - a.score);
    // Pick from top 3
    const top = scored.slice(0, Math.min(3, scored.length));
    return top[Math.floor(Math.random() * top.length)].plat;
  }

  function landOnPlatform(plat) {
    prince.onPlatform = plat;
    prince.y = plat.y;
    prince.vy = 0;
    prince.state = "running";
    prince.idleTimer = 0;
    // Track visited
    prince.visitedPlatforms.unshift(plat);
    if (prince.visitedPlatforms.length > 6) prince.visitedPlatforms.pop();

    if (prince.x < plat.x + plat.w / 2) {
      prince.facingRight = true;
      prince.vx = RUN_SPEED;
    } else {
      prince.facingRight = false;
      prince.vx = -RUN_SPEED;
    }
  }

  function startClimb(plat) {
    prince.state = "climbing";
    prince.climbTimer = 0;
    prince.climbTarget = plat;
    prince.vx = 0;
    prince.vy = 0;
    prince.x = Math.max(plat.x + 6, Math.min(plat.x + plat.w - 6, prince.x));
    prince.y = plat.y;
  }

  function jump(targetPlat) {
    // Vary jump force based on vertical distance
    const dy = targetPlat ? (prince.y - targetPlat.y) : 0;
    prince.vy = dy > 50 ? JUMP_FORCE * 1.4 : JUMP_FORCE;
    prince.state = "jumping";
    prince.onPlatform = null;

    // Randomly do a flip (20% chance)
    if (Math.random() < 0.2) {
      prince.state = "flipping";
      prince.flipFrame = 0;
      prince.flipTimer = 0;
      prince.vy = JUMP_FORCE * 1.2;
    }

    if (targetPlat) {
      prince.facingRight = targetPlat.x + targetPlat.w / 2 > prince.x;
      const dx = (targetPlat.x + targetPlat.w / 2) - prince.x;
      prince.vx = Math.sign(dx) * Math.min(Math.abs(dx) / 40, RUN_SPEED * 2.5);
    }
  }

  function startIdle() {
    prince.state = "idle";
    prince.idleTimer = 0;
    prince.vx = 0;
    // Pick random idle behavior
    const r = Math.random();
    if (r < 0.25) prince.idleType = 0; // stand and look
    else if (r < 0.45) prince.idleType = 1; // scratch head
    else if (r < 0.65) prince.idleType = 2; // peer off edge
    else if (r < 0.80) prince.idleType = 3; // sit and rest
    else prince.idleType = 4; // turn around
  }

  // --- Init ---
  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener("resize", resize);

  function refreshPlatforms() { platforms = findPlatforms(); }
  refreshPlatforms();
  let scrollTimer;
  window.addEventListener("scroll", () => {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(refreshPlatforms, 150);
  }, { passive: true });
  setInterval(refreshPlatforms, 3000);

  setTimeout(() => {
    const p = pickNextPlatform(null);
    if (p) { prince.x = p.x + p.w * 0.3; landOnPlatform(p); }
  }, 1500);

  // --- Draw ---
  function drawSprite(sprite, x, y) {
    ctx.fillStyle = COLOR;
    ctx.shadowColor = COLOR;
    ctx.shadowBlur = 3;
    for (const [x1, y1, x2, y2] of sprite.lines) {
      drawLine(x1, y1, x2, y2, x, y);
    }
    ctx.shadowBlur = 0;
  }

  // --- Update ---
  function update() {
    const p = prince;

    p.frameTimer++;
    if (p.frameTimer >= FRAME_DELAY) {
      p.frameTimer = 0;
      p.frame = (p.frame + 1) % 4;
    }

    // === CLIMBING ===
    if (p.state === "climbing") {
      p.climbTimer++;
      if (p.climbTimer > CLIMB_DURATION + PULLUP_DURATION) {
        landOnPlatform(p.climbTarget);
        p.climbTarget = null;
      }
      return;
    }

    // === IDLE ===
    if (p.state === "idle") {
      p.idleTimer++;
      const duration = p.idleType === 3 ? 180 : (p.idleType === 2 ? 90 : 70);
      if (p.idleTimer > duration) {
        if (p.idleType === 4) {
          // Turn around and resume
          p.facingRight = !p.facingRight;
          p.vx = p.facingRight ? RUN_SPEED : -RUN_SPEED;
          p.state = "running";
        } else if (p.idleType === 2 && Math.random() < 0.5) {
          // After peering, sometimes jump off!
          const target = pickNextPlatform(p.onPlatform);
          if (target) jump(target);
          else { p.state = "running"; p.vx = p.facingRight ? RUN_SPEED : -RUN_SPEED; }
        } else {
          p.state = "running";
          p.vx = p.facingRight ? RUN_SPEED : -RUN_SPEED;
        }
      }
      return;
    }

    // === RUNNING ===
    if (p.state === "running" && p.onPlatform) {
      p.x += p.vx;

      const plat = p.onPlatform;

      // Near end of platform
      if (p.x < plat.x + 3 || p.x > plat.x + plat.w - 3) {
        const r = Math.random();
        if (r < 0.3) {
          // Peer off edge before jumping
          startIdle();
          p.idleType = 2;
          return;
        }
        // Jump to next
        const target = pickNextPlatform(plat);
        if (target) jump(target);
        else { p.facingRight = !p.facingRight; p.vx = -p.vx; } // no target, turn around
        return;
      }

      // Random behaviors while running
      const r = Math.random();
      if (r < 0.003) {
        // Random stop for idle
        startIdle();
      } else if (r < 0.005) {
        // Random jump mid-platform
        const target = pickNextPlatform(plat);
        if (target) jump(target);
      } else if (r < 0.006) {
        // Change speed briefly
        p.vx = (p.facingRight ? 1 : -1) * RUN_SPEED * (0.4 + Math.random() * 1.2);
      }
      return;
    }

    // === AIRBORNE (jumping / falling / flipping) ===
    p.vy += GRAVITY;
    p.x += p.vx;
    p.y += p.vy;

    if (p.state === "flipping") {
      p.flipTimer++;
      if (p.flipTimer % 8 === 0) {
        p.flipFrame = (p.flipFrame + 1) % 3;
      }
      if (p.vy > 0) p.state = "falling";
    } else {
      if (p.vy > 0) p.state = "falling";
    }

    // Check landing or climb
    for (const plat of platforms) {
      const inX = p.x > plat.x - 6 && p.x < plat.x + plat.w + 6;
      if (!inX) continue;

      // Landing on top
      if (p.vy > 0 && p.y >= plat.y && p.y - p.vy < plat.y + 8) {
        landOnPlatform(plat);
        return;
      }

      // Climb: near platform from below, slowing down
      if (p.vy > -1 && p.vy < 2 && p.y > plat.y && p.y < plat.y + 22) {
        startClimb(plat);
        return;
      }
    }

    // Off screen reset
    if (p.y > window.innerHeight + 50 || p.x < -100 || p.x > window.innerWidth + 100) {
      const target = pickNextPlatform(null);
      if (target) { p.x = target.x + target.w * 0.3; landOnPlatform(target); }
      else { p.x = window.innerWidth / 2; p.y = 100; p.vy = 0; p.state = "falling"; }
    }
  }

  // --- Render ---
  function loop() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    update();

    const p = prince;
    let sprite;

    if (p.state === "climbing") {
      if (p.climbTimer < CLIMB_DURATION) {
        sprite = p.facingRight ? climbGrab : climbGrabLeft;
        const progress = p.climbTimer / CLIMB_DURATION;
        drawSprite(sprite, p.x, p.climbTarget.y + 12 * (1 - progress));
      } else {
        sprite = p.facingRight ? climbPull : climbPullLeft;
        const progress = (p.climbTimer - CLIMB_DURATION) / PULLUP_DURATION;
        drawSprite(sprite, p.x, p.climbTarget.y + 4 * (1 - progress));
      }
    } else if (p.state === "flipping") {
      sprite = flipFrames[p.flipFrame];
      drawSprite(sprite, p.x, p.y);
    } else if (p.state === "jumping") {
      sprite = p.facingRight ? jumpUp : jumpUpLeft;
      drawSprite(sprite, p.x, p.y);
    } else if (p.state === "falling") {
      sprite = p.facingRight ? jumpUp : jumpUpLeft;
      drawSprite(sprite, p.x, p.y);
    } else if (p.state === "idle") {
      if (p.idleType === 0) sprite = idleStand;
      else if (p.idleType === 1) sprite = p.frameTimer < 7 ? idleScratch : idleStand; // alternate
      else if (p.idleType === 2) sprite = p.facingRight ? idlePeer : idlePeerLeft;
      else if (p.idleType === 3) sprite = idleSit;
      else sprite = idleStand; // turn around uses standing
      drawSprite(sprite, p.x, p.y);
    } else {
      // Running
      const frames = p.facingRight ? runRight : runLeft;
      sprite = frames[p.frame];
      drawSprite(sprite, p.x, p.y);
    }

    requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);
})();
</script>
