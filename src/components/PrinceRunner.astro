---
// Tiny pixel character that runs across text lines like platforms.
// Inspired by Prince of Persia — lands on text, runs along it, jumps to another line.
---

<canvas id="prince-canvas"></canvas>

<style>
  #prince-canvas {
    position: fixed;
    inset: 0;
    z-index: 50;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    #prince-canvas { display: none; }
  }
</style>

<script is:inline>
(() => {
  const canvas = document.getElementById("prince-canvas");
  if (!canvas) return;
  if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    canvas.style.display = "none";
    return;
  }
  const ctx = canvas.getContext("2d");

  // --- Pixel sprite frames (16x16, Prince of Persia style running) ---
  // Each frame is an array of [x, y] pixel coordinates to fill
  // Drawn in #4eff7c (site green)

  const SPRITE_SIZE = 16;
  const SCALE = 1.2; // render size multiplier

  // Running frames — 4-frame cycle, facing right
  const runFramesRight = [
    // Frame 0: right foot forward
    [
      // head
      [7,1],[8,1],[7,2],[8,2],
      // hair
      [6,0],[7,0],[8,0],[9,0],
      // body
      [7,3],[8,3],[7,4],[8,4],[7,5],[8,5],[7,6],[8,6],
      // right arm forward
      [9,4],[10,4],[11,5],
      // left arm back
      [6,5],[5,5],
      // right leg forward
      [9,7],[10,8],[11,9],
      // left leg back
      [6,7],[5,8],[4,9],
    ],
    // Frame 1: legs together (passing)
    [
      [7,1],[8,1],[7,2],[8,2],
      [6,0],[7,0],[8,0],[9,0],
      [7,3],[8,3],[7,4],[8,4],[7,5],[8,5],[7,6],[8,6],
      [9,4],[10,5],
      [6,4],[5,5],
      [7,7],[7,8],[7,9],
      [8,7],[8,8],[8,9],
    ],
    // Frame 2: left foot forward
    [
      [7,1],[8,1],[7,2],[8,2],
      [6,0],[7,0],[8,0],[9,0],
      [7,3],[8,3],[7,4],[8,4],[7,5],[8,5],[7,6],[8,6],
      [6,4],[5,4],[4,5],
      [9,5],[10,5],
      [6,7],[5,8],[4,9],
      [9,7],[10,8],[11,9],
    ],
    // Frame 3: legs together (passing) - same as 1
    [
      [7,1],[8,1],[7,2],[8,2],
      [6,0],[7,0],[8,0],[9,0],
      [7,3],[8,3],[7,4],[8,4],[7,5],[8,5],[7,6],[8,6],
      [6,4],[5,5],
      [9,4],[10,5],
      [7,7],[8,7],[7,8],[8,8],[7,9],[8,9],
    ],
  ];

  // Jump frame
  const jumpFrame = [
    [7,0],[8,0],[7,1],[8,1],
    [6,-1],[7,-1],[8,-1],[9,-1],
    [7,2],[8,2],[7,3],[8,3],[7,4],[8,4],[7,5],[8,5],
    // arms up
    [5,2],[6,2],[9,2],[10,2],
    // legs tucked
    [6,6],[5,6],[9,6],[10,6],
  ];

  // Mirror frames for facing left
  function mirrorFrame(frame) {
    return frame.map(([x, y]) => [SPRITE_SIZE - 1 - x, y]);
  }
  const runFramesLeft = runFramesRight.map(mirrorFrame);
  const jumpFrameLeft = mirrorFrame(jumpFrame);

  // --- Platform detection (find text bounding boxes) ---
  function findPlatforms() {
    const platforms = [];
    // Query all visible text elements
    const selectors = "h1, h2, h3, p, a, span, li, div, time, code, td, th";
    const els = document.querySelectorAll("#app " + selectors);
    const seen = new Set();

    for (const el of els) {
      // Skip hidden or empty
      if (!el.offsetParent && el.id !== "app") continue;
      const text = el.textContent?.trim();
      if (!text || text.length < 2) continue;

      const rect = el.getBoundingClientRect();
      if (rect.width < 30 || rect.height < 8 || rect.height > 60) continue;
      if (rect.top < 0 || rect.bottom > window.innerHeight) continue;

      // Deduplicate by rounding position
      const key = Math.round(rect.top / 4) + ":" + Math.round(rect.left / 10);
      if (seen.has(key)) continue;
      seen.add(key);

      platforms.push({
        x: rect.left,
        y: rect.top,
        w: rect.width,
        h: rect.height,
        // The character runs on top of the text
        surfaceY: rect.top,
      });
    }
    return platforms;
  }

  // --- Character state ---
  let platforms = [];
  let prince = {
    x: 100,
    y: 200,
    vx: 1.8,
    vy: 0,
    facingRight: true,
    onPlatform: null,
    jumping: false,
    frame: 0,
    frameTimer: 0,
    idleTimer: 0,
    state: "running", // running, jumping, falling, idle
  };

  const GRAVITY = 0.25;
  const JUMP_FORCE = -5.5;
  const RUN_SPEED = 1.8;
  const FRAME_DELAY = 8; // ticks per animation frame

  function pickRandomPlatform(exclude) {
    const valid = platforms.filter(p => p !== exclude && p.w > 40);
    return valid.length ? valid[Math.floor(Math.random() * valid.length)] : null;
  }

  function landOnPlatform(p) {
    prince.onPlatform = p;
    prince.y = p.surfaceY;
    prince.vy = 0;
    prince.jumping = false;
    prince.state = "running";
    // Face direction based on position on platform
    if (prince.x < p.x + p.w / 2) {
      prince.facingRight = true;
      prince.vx = RUN_SPEED;
    } else {
      prince.facingRight = false;
      prince.vx = -RUN_SPEED;
    }
  }

  function jump() {
    prince.vy = JUMP_FORCE;
    prince.jumping = true;
    prince.state = "jumping";
    prince.onPlatform = null;
  }

  // --- Init ---
  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener("resize", resize);

  // Refresh platforms periodically and on scroll
  function refreshPlatforms() {
    platforms = findPlatforms();
  }
  refreshPlatforms();
  let scrollTimer;
  window.addEventListener("scroll", () => {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(refreshPlatforms, 150);
  }, { passive: true });
  setInterval(refreshPlatforms, 3000);

  // Start on a random platform
  function initPrince() {
    const p = pickRandomPlatform(null);
    if (p) {
      prince.x = p.x + p.w * 0.3;
      landOnPlatform(p);
    }
  }
  setTimeout(initPrince, 1500);

  // --- Draw ---
  function drawSprite(frame, x, y) {
    const s = SCALE;
    ctx.fillStyle = "#4eff7c";
    ctx.shadowColor = "#4eff7c";
    ctx.shadowBlur = 4;
    for (const [px, py] of frame) {
      ctx.fillRect(
        Math.round(x + px * s),
        Math.round(y + py * s - SPRITE_SIZE * s),
        Math.ceil(s),
        Math.ceil(s)
      );
    }
    ctx.shadowBlur = 0;
  }

  // --- Update ---
  function update() {
    const p = prince;

    // Advance animation frame
    p.frameTimer++;
    if (p.frameTimer >= FRAME_DELAY) {
      p.frameTimer = 0;
      p.frame = (p.frame + 1) % 4;
    }

    if (p.state === "running" && p.onPlatform) {
      // Run along platform
      p.x += p.vx;

      // Reached end of platform?
      const plat = p.onPlatform;
      if (p.x < plat.x - 5 || p.x > plat.x + plat.w + 5) {
        // Jump to another platform
        jump();
        // Aim toward a random platform
        const target = pickRandomPlatform(plat);
        if (target) {
          p.facingRight = target.x + target.w / 2 > p.x;
          p.vx = p.facingRight ? RUN_SPEED * 1.5 : -RUN_SPEED * 1.5;
        }
      }

      // Random jump while running (10% chance per second at 60fps)
      if (Math.random() < 0.002) {
        jump();
        const target = pickRandomPlatform(plat);
        if (target) {
          p.facingRight = target.x + target.w / 2 > p.x;
          p.vx = p.facingRight ? RUN_SPEED * 1.5 : -RUN_SPEED * 1.5;
        }
      }
    } else {
      // Airborne: jumping or falling
      p.vy += GRAVITY;
      p.x += p.vx;
      p.y += p.vy;

      if (p.vy > 0) p.state = "falling";

      // Check landing on platforms
      for (const plat of platforms) {
        if (
          p.vy > 0 &&
          p.x > plat.x - 10 &&
          p.x < plat.x + plat.w + 10 &&
          p.y >= plat.surfaceY &&
          p.y - p.vy < plat.surfaceY + 8
        ) {
          landOnPlatform(plat);
          break;
        }
      }

      // Off screen? Reset
      if (p.y > window.innerHeight + 50 || p.x < -100 || p.x > window.innerWidth + 100) {
        const target = pickRandomPlatform(null);
        if (target) {
          p.x = target.x + target.w * 0.3;
          landOnPlatform(target);
        } else {
          p.x = window.innerWidth / 2;
          p.y = 100;
          p.vy = 0;
          p.state = "falling";
        }
      }
    }
  }

  // --- Render loop ---
  function loop() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);

    update();

    // Pick frame
    let frame;
    if (prince.state === "jumping" || prince.state === "falling") {
      frame = prince.facingRight ? jumpFrame : jumpFrameLeft;
    } else {
      const frames = prince.facingRight ? runFramesRight : runFramesLeft;
      frame = frames[prince.frame];
    }

    drawSprite(frame, prince.x, prince.y);
    requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);
})();
</script>
