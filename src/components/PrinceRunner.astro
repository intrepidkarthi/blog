---
// Tiny pixel character that runs across text lines like platforms.
// Inspired by Prince of Persia — lands on text, runs along it, jumps to another line.
---

<canvas id="prince-canvas"></canvas>

<style>
  #prince-canvas {
    position: fixed;
    inset: 0;
    z-index: 50;
    pointer-events: none;
  }
  @media (prefers-reduced-motion: reduce) {
    #prince-canvas { display: none; }
  }
</style>

<script is:inline>
(() => {
  const canvas = document.getElementById("prince-canvas");
  if (!canvas) return;
  if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    canvas.style.display = "none";
    return;
  }
  const ctx = canvas.getContext("2d");

  const S = 1.2; // pixel scale
  const COLOR = "#4eff7c";

  // --- Hollow sprite drawing: only outline pixels ---
  // Each sprite is defined as lines to stroke (pairs of [x1,y1,x2,y2])
  // This gives a hollow stick-figure look

  function drawLine(x0, y0, x1, y1, baseX, baseY) {
    const dx = Math.abs(x1 - x0), dy = Math.abs(y1 - y0);
    const sx = x0 < x1 ? 1 : -1, sy = y0 < y1 ? 1 : -1;
    let err = dx - dy;
    while (true) {
      ctx.fillRect(Math.round(baseX + x0 * S), Math.round(baseY + y0 * S), Math.ceil(S), Math.ceil(S));
      if (x0 === x1 && y0 === y1) break;
      const e2 = 2 * err;
      if (e2 > -dy) { err -= dy; x0 += sx; }
      if (e2 < dx) { err += dx; y0 += sy; }
    }
  }

  // Sprite as line segments: [x1,y1, x2,y2] — hollow stick figure
  // Origin at feet (0,0 = bottom center)

  // Run right frames — stick figure, ~18px tall
  const runRight = [
    // Frame 0: right leg forward, left back
    {
      lines: [
        // head (circle-ish outline)
        [0,-17, 1,-18], [1,-18, 2,-18], [2,-18, 3,-17], [3,-17, 3,-16],
        [3,-16, 2,-15], [2,-15, 1,-15], [1,-15, 0,-16], [0,-16, 0,-17],
        // neck
        [1,-15, 1,-14],
        // torso
        [1,-14, 1,-8],
        // right arm forward
        [1,-13, 3,-12], [3,-12, 5,-13],
        // left arm back
        [1,-12, -1,-13], [-1,-13, -2,-12],
        // right leg forward
        [1,-8, 3,-5], [3,-5, 4,-2], [4,-2, 5,0],
        // left leg back
        [1,-8, -1,-5], [-1,-5, -2,-2], [-2,-2, -3,0],
      ]
    },
    // Frame 1: legs passing
    {
      lines: [
        [0,-17, 1,-18], [1,-18, 2,-18], [2,-18, 3,-17], [3,-17, 3,-16],
        [3,-16, 2,-15], [2,-15, 1,-15], [1,-15, 0,-16], [0,-16, 0,-17],
        [1,-15, 1,-14],
        [1,-14, 1,-8],
        [1,-13, 3,-13], [3,-13, 4,-12],
        [1,-12, -1,-12], [-1,-12, -2,-13],
        // legs straight down, close together
        [1,-8, 1,-4], [1,-4, 1,0],
        [1,-8, 2,-4], [2,-4, 2,0],
      ]
    },
    // Frame 2: left leg forward, right back
    {
      lines: [
        [0,-17, 1,-18], [1,-18, 2,-18], [2,-18, 3,-17], [3,-17, 3,-16],
        [3,-16, 2,-15], [2,-15, 1,-15], [1,-15, 0,-16], [0,-16, 0,-17],
        [1,-15, 1,-14],
        [1,-14, 1,-8],
        // left arm forward
        [1,-13, -1,-12], [-1,-12, -3,-13],
        // right arm back
        [1,-12, 3,-13], [3,-13, 4,-12],
        // left leg forward
        [1,-8, 3,-5], [3,-5, 4,-2], [4,-2, 5,0],
        // right leg back
        [1,-8, -1,-5], [-1,-5, -2,-2], [-2,-2, -3,0],
      ]
    },
    // Frame 3: legs passing (same as 1)
    {
      lines: [
        [0,-17, 1,-18], [1,-18, 2,-18], [2,-18, 3,-17], [3,-17, 3,-16],
        [3,-16, 2,-15], [2,-15, 1,-15], [1,-15, 0,-16], [0,-16, 0,-17],
        [1,-15, 1,-14],
        [1,-14, 1,-8],
        [1,-13, 3,-13], [3,-13, 4,-12],
        [1,-12, -1,-12], [-1,-12, -2,-13],
        [1,-8, 1,-4], [1,-4, 1,0],
        [1,-8, 2,-4], [2,-4, 2,0],
      ]
    },
  ];

  // Jump frame — arms reaching up, legs tucked (mid-air leap)
  const jumpUp = {
    lines: [
      // head
      [0,-19, 1,-20], [1,-20, 2,-20], [2,-20, 3,-19], [3,-19, 3,-18],
      [3,-18, 2,-17], [2,-17, 1,-17], [1,-17, 0,-18], [0,-18, 0,-19],
      [1,-17, 1,-16],
      // torso
      [1,-16, 1,-10],
      // arms reaching UP (grabbing)
      [1,-15, -1,-17], [-1,-17, -2,-19],
      [1,-15, 3,-17], [3,-17, 4,-19],
      // legs tucked up
      [1,-10, 3,-9], [3,-9, 4,-10],
      [1,-10, -1,-9], [-1,-9, -2,-10],
    ]
  };

  // Climb/grab frame — hanging from ledge, pulling up
  const climbGrab = {
    lines: [
      // head
      [0,-17, 1,-18], [1,-18, 2,-18], [2,-18, 3,-17], [3,-17, 3,-16],
      [3,-16, 2,-15], [2,-15, 1,-15], [1,-15, 0,-16], [0,-16, 0,-17],
      [1,-15, 1,-14],
      // torso
      [1,-14, 1,-8],
      // arms UP gripping ledge
      [1,-14, -1,-16], [-1,-16, -2,-17],
      [1,-14, 3,-16], [3,-16, 4,-17],
      // legs dangling
      [1,-8, 0,-5], [0,-5, -1,-3],
      [1,-8, 2,-5], [2,-5, 3,-3],
    ]
  };

  // Climb pull-up frame — almost on top
  const climbPull = {
    lines: [
      // head higher
      [0,-19, 1,-20], [1,-20, 2,-20], [2,-20, 3,-19], [3,-19, 3,-18],
      [3,-18, 2,-17], [2,-17, 1,-17], [1,-17, 0,-18], [0,-18, 0,-19],
      [1,-17, 1,-16],
      // torso
      [1,-16, 1,-10],
      // arms pushing down on ledge
      [1,-14, -1,-13], [-1,-13, -3,-13],
      [1,-14, 3,-13], [3,-13, 5,-13],
      // legs curling up
      [1,-10, 2,-8], [2,-8, 1,-6],
      [1,-10, 0,-8], [0,-8, 1,-6],
    ]
  };

  // Mirror a frame horizontally
  function mirrorSprite(spr) {
    return {
      lines: spr.lines.map(([x1,y1,x2,y2]) => [-x1,y1,-x2,y2])
    };
  }

  const runLeft = runRight.map(mirrorSprite);
  const jumpUpLeft = mirrorSprite(jumpUp);
  const climbGrabLeft = mirrorSprite(climbGrab);
  const climbPullLeft = mirrorSprite(climbPull);

  // --- Platform detection ---
  function findPlatforms() {
    const platforms = [];
    const selectors = "h1, h2, h3, p, a, span, li, div, time, code, td, th";
    const els = document.querySelectorAll("#app " + selectors);
    const seen = new Set();

    for (const el of els) {
      if (!el.offsetParent && el.id !== "app") continue;
      const text = el.textContent?.trim();
      if (!text || text.length < 2) continue;

      const rect = el.getBoundingClientRect();
      if (rect.width < 30 || rect.height < 8 || rect.height > 60) continue;
      if (rect.top < 0 || rect.bottom > window.innerHeight) continue;

      const key = Math.round(rect.bottom / 4) + ":" + Math.round(rect.left / 10);
      if (seen.has(key)) continue;
      seen.add(key);

      platforms.push({
        x: rect.left,
        y: rect.bottom,  // feet land on bottom edge of text
        w: rect.width,
        topY: rect.top,  // top edge for climb detection
      });
    }
    return platforms;
  }

  // --- Character state ---
  let platforms = [];
  let prince = {
    x: 100,
    y: 200,
    vx: 0,
    vy: 0,
    facingRight: true,
    onPlatform: null,
    frame: 0,
    frameTimer: 0,
    state: "falling", // running, jumping, falling, climbing, pullup
    climbTimer: 0,
    climbTarget: null,
  };

  const GRAVITY = 0.18;
  const JUMP_FORCE = -4.5;
  const RUN_SPEED = 0.8;
  const FRAME_DELAY = 12; // ticks per animation frame (slower)
  const CLIMB_DURATION = 40; // ticks to climb
  const PULLUP_DURATION = 20;

  function pickRandomPlatform(exclude) {
    const valid = platforms.filter(p => p !== exclude && p.w > 40);
    return valid.length ? valid[Math.floor(Math.random() * valid.length)] : null;
  }

  function landOnPlatform(p) {
    prince.onPlatform = p;
    prince.y = p.y;
    prince.vy = 0;
    prince.state = "running";
    if (prince.x < p.x + p.w / 2) {
      prince.facingRight = true;
      prince.vx = RUN_SPEED;
    } else {
      prince.facingRight = false;
      prince.vx = -RUN_SPEED;
    }
  }

  function startClimb(plat) {
    prince.state = "climbing";
    prince.climbTimer = 0;
    prince.climbTarget = plat;
    prince.vx = 0;
    prince.vy = 0;
    // Snap x to platform edge
    if (prince.x < plat.x + plat.w / 2) {
      prince.x = plat.x + 4;
    } else {
      prince.x = plat.x + plat.w - 4;
    }
    prince.y = plat.y; // hang from bottom of text line
  }

  function jump() {
    prince.vy = JUMP_FORCE;
    prince.state = "jumping";
    prince.onPlatform = null;
  }

  // --- Init ---
  function resize() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener("resize", resize);

  function refreshPlatforms() {
    platforms = findPlatforms();
  }
  refreshPlatforms();
  let scrollTimer;
  window.addEventListener("scroll", () => {
    clearTimeout(scrollTimer);
    scrollTimer = setTimeout(refreshPlatforms, 150);
  }, { passive: true });
  setInterval(refreshPlatforms, 3000);

  function initPrince() {
    const p = pickRandomPlatform(null);
    if (p) {
      prince.x = p.x + p.w * 0.3;
      landOnPlatform(p);
    }
  }
  setTimeout(initPrince, 1500);

  // --- Draw ---
  function drawSprite(sprite, x, y) {
    ctx.fillStyle = COLOR;
    ctx.shadowColor = COLOR;
    ctx.shadowBlur = 3;
    for (const [x1, y1, x2, y2] of sprite.lines) {
      drawLine(x1, y1, x2, y2, x, y);
    }
    ctx.shadowBlur = 0;
  }

  // --- Update ---
  function update() {
    const p = prince;

    // Advance animation frame
    p.frameTimer++;
    if (p.frameTimer >= FRAME_DELAY) {
      p.frameTimer = 0;
      p.frame = (p.frame + 1) % 4;
    }

    if (p.state === "climbing") {
      // Climbing: hang, then pull up
      p.climbTimer++;
      if (p.climbTimer > CLIMB_DURATION + PULLUP_DURATION) {
        // Done climbing, now on platform
        landOnPlatform(p.climbTarget);
        p.climbTarget = null;
      }
      return;
    }

    if (p.state === "running" && p.onPlatform) {
      p.x += p.vx;

      const plat = p.onPlatform;
      if (p.x < plat.x - 5 || p.x > plat.x + plat.w + 5) {
        // End of platform — jump
        jump();
        const target = pickRandomPlatform(plat);
        if (target) {
          p.facingRight = target.x + target.w / 2 > p.x;
          p.vx = p.facingRight ? RUN_SPEED * 1.8 : -RUN_SPEED * 1.8;
        }
      }

      // Random jump
      if (Math.random() < 0.0015) {
        jump();
        const target = pickRandomPlatform(plat);
        if (target) {
          p.facingRight = target.x + target.w / 2 > p.x;
          p.vx = p.facingRight ? RUN_SPEED * 1.8 : -RUN_SPEED * 1.8;
        }
      }
    } else if (p.state === "jumping" || p.state === "falling") {
      p.vy += GRAVITY;
      p.x += p.vx;
      p.y += p.vy;

      if (p.vy > 0) p.state = "falling";

      // Check landing or climb
      for (const plat of platforms) {
        const inX = p.x > plat.x - 8 && p.x < plat.x + plat.w + 8;
        if (!inX) continue;

        // Landing on top (falling down onto platform)
        if (
          p.vy > 0 &&
          p.y >= plat.y &&
          p.y - p.vy < plat.y + 6
        ) {
          landOnPlatform(plat);
          break;
        }

        // Climb: coming from below, grab the platform edge
        // Character is rising or just started falling, and head is near platform bottom
        if (
          p.y > plat.y &&
          p.y < plat.y + 25 &&
          Math.abs(p.vy) < 3
        ) {
          startClimb(plat);
          break;
        }
      }

      // Off screen? Reset
      if (p.y > window.innerHeight + 50 || p.x < -100 || p.x > window.innerWidth + 100) {
        const target = pickRandomPlatform(null);
        if (target) {
          p.x = target.x + target.w * 0.3;
          landOnPlatform(target);
        } else {
          p.x = window.innerWidth / 2;
          p.y = 100;
          p.vy = 0;
          p.state = "falling";
        }
      }
    }
  }

  // --- Render loop ---
  function loop() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    update();

    const p = prince;
    let sprite;

    if (p.state === "climbing") {
      if (p.climbTimer < CLIMB_DURATION) {
        // Hanging / grabbing
        sprite = p.facingRight ? climbGrab : climbGrabLeft;
        // Slowly move up
        const progress = p.climbTimer / CLIMB_DURATION;
        const hangY = p.climbTarget.y + 12 * (1 - progress);
        drawSprite(sprite, p.x, hangY);
      } else {
        // Pulling up
        sprite = p.facingRight ? climbPull : climbPullLeft;
        const progress = (p.climbTimer - CLIMB_DURATION) / PULLUP_DURATION;
        const pullY = p.climbTarget.y + 4 * (1 - progress);
        drawSprite(sprite, p.x, pullY);
      }
    } else if (p.state === "jumping") {
      sprite = p.facingRight ? jumpUp : jumpUpLeft;
      drawSprite(sprite, p.x, p.y);
    } else if (p.state === "falling") {
      // Falling — legs down, arms out
      sprite = p.facingRight ? jumpUp : jumpUpLeft;
      drawSprite(sprite, p.x, p.y);
    } else {
      // Running
      const frames = p.facingRight ? runRight : runLeft;
      sprite = frames[p.frame];
      drawSprite(sprite, p.x, p.y);
    }

    requestAnimationFrame(loop);
  }

  requestAnimationFrame(loop);
})();
</script>
