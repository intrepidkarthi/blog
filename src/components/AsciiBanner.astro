<style>
  .banner-wrap {
    text-align: center;
    padding: 18px 0 24px;
    margin-bottom: 12px;
    border-bottom: 1px dashed var(--line);
    position: relative;
  }
  .banner {
    display: inline-block;
    color: var(--green-bright);
    font-family: var(--font-mono);
    font-size: 9px;
    line-height: 1.05;
    letter-spacing: 0;
    white-space: pre;
    text-shadow:
      0 0 4px var(--green-glow),
      0 0 10px rgba(78, 255, 124, 0.25);
    margin: 0 auto;
    user-select: none;
    overflow-x: auto;
    max-width: 100%;
  }
  .banner .line {
    display: block;
    animation: type-in 0.8s ease-out both;
  }
  .banner .acc { color: var(--amber); text-shadow: 0 0 4px rgba(255, 180, 84, 0.5); }
  .banner .line:nth-child(1) { animation-delay: 0.05s; }
  .banner .line:nth-child(2) { animation-delay: 0.10s; }
  .banner .line:nth-child(3) { animation-delay: 0.15s; }
  .banner .line:nth-child(4) { animation-delay: 0.20s; }
  .banner .line:nth-child(5) { animation-delay: 0.25s; }
  .banner .line:nth-child(6) { animation-delay: 0.30s; }
  .banner .line:nth-child(7) { animation-delay: 0.40s; }
  .banner .line:nth-child(8) { animation-delay: 0.45s; }
  .banner .line:nth-child(9) { animation-delay: 0.50s; }
  .banner .line:nth-child(10) { animation-delay: 0.55s; }
  .banner .line:nth-child(11) { animation-delay: 0.60s; }
  .banner .line:nth-child(12) { animation-delay: 0.65s; }
  @keyframes type-in {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* small viewports */
  @media (max-width: 800px) {
    .banner { font-size: 7px; }
  }
  @media (max-width: 520px) {
    .banner { font-size: 5px; }
  }

  .sub {
    margin-top: 18px;
    color: var(--ink);
    font-size: 13px;
    letter-spacing: 1px;
    animation: type-in 0.8s ease-out 0.85s both;
  }
  .sub .b { color: var(--pink); }
  .sub .dot {
    display: inline-block;
    width: 4px; height: 4px; border-radius: 50%;
    background: var(--green);
    margin: 0 8px;
    vertical-align: middle;
    box-shadow: 0 0 4px var(--green);
  }

  .hint {
    margin-top: 14px;
    color: var(--dim);
    font-size: 11px;
    letter-spacing: 1px;
    animation: type-in 0.8s ease-out 1.0s both;
  }
  .hint kbd {
    background: var(--bg2);
    border: 1px solid var(--line-bright);
    color: var(--green-bright);
    padding: 1px 7px;
    border-radius: 3px;
    font-family: inherit;
    font-size: 10px;
    margin: 0 2px;
  }
  .hint .sep { color: var(--line-bright); margin: 0 6px; }
</style>
